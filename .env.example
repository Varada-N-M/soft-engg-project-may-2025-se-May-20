# Database Configuration
# For PostgreSQL (recommended):
# DATABASE_URL=postgresql://username:password@localhost:5432/growwise_db

# For PostgreSQL with Docker Compose:
# DATABASE_URL=postgresql://growwise_user:growwise_password@postgres:5432/growwise_db

# For SQLite (local development fallback - no DATABASE_URL needed):
# If DATABASE_URL is not set, the app will automatically use SQLite

# Flask Configuration
SECRET_KEY=your-secret-key-here
FRONTEND_URL=http://localhost:3000

# JWT Configuration
JWT_KEY=your_jwt_secret_key
JWT_ACCESS_TOKEN_EXPIRES=your_jwt_access_token_expires
JWT_REFRESH_TOKEN_EXPIRES=your_jwt_refresh_token_expires

# Google Generative AI Configuration
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=your_gemini_model

# Email Configuration
MAIL_SERVER=your_mail_server
MAIL_PORT=your_mail_port
MAIL_USE_TLS=your_mail_use_tls
MAIL_USE_SSL=your_mail_use_ssl
MAIL_USERNAME=your_mail_username
MAIL_PASSWORD=your_mail_password